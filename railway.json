{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd cv-berdikari-backend && npm run build",
    "startCommand": "cd cv-berdikari-backend && npm run start:prod",
    "watchPatterns": ["cv-berdikari-backend/**"]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
